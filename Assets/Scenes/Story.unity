  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1437264568}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 296ed5b8d91ddc34a8469fa8103bce65, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  backgroundImageA: {fileID: 1683506546}
  backgroundImageB: {fileID: 442479780}
  storyText: {fileID: 1407981639}
  skipButton: {fileID: 743752641}
  sfxSource: {fileID: 1437264571}
  typingClip: {fileID: 8300000, guid: d80aacbb932e67341ab2aaa714250c59, type: 3}
  typingVolume: 1
  slides:
  - image: {fileID: 21300000, guid: 60d90cee5e87f1e4fa84ede688208d7b, type: 3}
    text: "C\xE2u chuy\u1EC7n k\u1EC3 v\u1EC1 m\u1ED9t n\xE0ng c\xF4ng ch\xFAa \u0111\u1EB9p
      tuy\u1EC7t tr\u1EA7n \u1EDF m\u1ED9t v\u01B0\u01A1ng qu\u1ED1c n\u1ECD. H\u1EB1ng
      ng\xE0y, n\xE0ng s\u1ED1ng trong ni\u1EC1m vui v\u1EBB, h\u1EA1nh ph\xFAc,
      ca h\xE1t m\u1ED7i ng\xE0y."
    waitTime: 3
  - image: {fileID: 21300000, guid: b26a44992ff4fd14495dc27e0bf211ef, type: 3}
    text: "B\u1ED7ng m\u1ED9t ng\xE0y, ma v\u01B0\u01A1ng xu\u1EA5t hi\u1EC7n t\u1EA1i
      gi\u1EEFa l\xE2u \u0111\xE0i, h\u1EAFn \u0111\xE3 b\u1EAFt c\xF4ng ch\xFAa
      \u0111i tr\u01B0\u1EDBc m\u1EB7t nh\xE0 vua."
    waitTime: 3
  - image: {fileID: 21300000, guid: 4039f0a105c36284aa5dbe9194ca5055, type: 3}
    text: "Nh\xE0 vua \u0111\xE3 ra l\u1EC7nh ch\xE0ng hi\u1EC7p s\u0129 c\u1EE7a
      v\u01B0\u01A1ng qu\u1ED1c l\xEAn \u0111\u01B0\u1EDDng ti\xEAu di\u1EC7t ma
      v\u01B0\u01A1ng, gi\u1EA3i c\u1EE9u c\xF4ng ch\xFAa tr\u1EDF v\u1EC1."
    waitTime: 3
  - image: {fileID: 21300000, guid: 6dc0a75c363d972449144d9a6cea4089, type: 3}
    text: "Ch\xE0ng \u0111\xE3 s\u1EB5n s\xE0ng l\xEAn \u0111\u01B0\u1EDDng. V\u1EDBi
      s\u1EE9c m\u1EA1nh c\u1EE7a m\xECnh, ch\xE0ng quy\u1EBFt t\xE2m gi\u1EA3i c\u1EE9u
      c\xF4ng ch\xFAa tr\u1EDF v\u1EC1. T\u1EEB \u0111\xE2y c\xE2u chuy\u1EC7n v\u1EC1
      ch\xE0ng hi\u1EC7p s\u0129 ch\u1ED1ng l\u1EA1i ma v\u01B0\u01A1ng gi\u1EA3i
      c\u1EE9u c\xF4ng ch\xFAa \u0111\xE3 b\u1EAFt \u0111\u1EA7u..."
    waitTime: 3
  fadeDuration: 1.5
  typingSpeed: 0.05
  erasingSpeed: 0.02
